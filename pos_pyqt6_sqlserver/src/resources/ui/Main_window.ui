    border-top-right-radius: 4px;
    margin-right: 2px;
}

/* ពណ៌នៅពេលដែលយើងចុចលើ Tab នោះ (Active Tab) */
QTabBar::tab:selected {
    background: #0078d7;    /* ពណ៌ខៀវ */
    font-weight: bold;
}

/* ពណ៌នៅពេលយើងយក Mouse ទៅដាក់ពីលើ (Hover) */
