     <string notr="true">/* កំណត់ពណ៌ទូទៅសម្រាប់ Tab ក្បាលលើ */
QTabBar::tab {
    background: #444;       /* ពណ៌ប្រផេះដិត */
    color: white;           /* ពណ៌អក្សរ */
    padding: 10px 20px;
